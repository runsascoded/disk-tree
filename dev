#!/usr/bin/env bash
# Start FE (Vite HMR) + BE (Flask debug/reload) for development.
# Open http://localhost:5180 for the full dev experience.
set -euo pipefail

cd "$(dirname "$0")"

cleanup() {
    echo "Shutting down..."
    kill $BE_PID $FE_PID 2>/dev/null
    wait $BE_PID $FE_PID 2>/dev/null
}
trap cleanup EXIT

# BE: Flask with debug/reload on :5001
FLASK_DEBUG=1 disk-tree-server &
BE_PID=$!

# FE: Vite dev server with HMR on :5180, proxies /api → :5001
cd ui
pnpm dev &
FE_PID=$!

echo ""
echo "  BE: http://localhost:5001  (Flask, auto-reload)"
echo "  FE: http://localhost:5180  (Vite, HMR)"
echo ""

wait
